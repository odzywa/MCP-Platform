# ─────────────────────────────────────────────
# MCP Platform — environment configuration
# Copy this file to .env and adjust values
# ─────────────────────────────────────────────

# Port on which the MCP Platform UI is accessible
MCP_PLATFORM_PORT=18100

# Absolute path to the data/ directory on the HOST machine
# Used by the operator to mount configs into runtime containers
# Example: /opt/mcp-platform/data  or  /home/user/mcp-platform/data
MCP_HOST_DATA_PATH=/opt/mcp-platform/data

# Base URL used to build runtime endpoint URLs (visible to clients)
# Use your server's IP or hostname — no trailing slash
MCP_RUNTIME_PUBLIC_BASE_URL=http://localhost

# Starting port for dynamically created runtime containers
MCP_RUNTIME_PUBLIC_PORT_BASE=19000
